# Normalise line endings: store LF in the repo, let Git convert on checkout.
* text=auto

# Scripts that RUN on Linux/HPC must stay LF — CRLF breaks the shebang
# (#!/bin/bash^M: bad interpreter) and Slurm jobs.
*.sh    text eol=lf
*.slurm text eol=lf
*.py    text eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files Git must not touch
*.png   binary
*.jpg   binary
*.pdf   binary
*.faiss binary
*.bin   binary
