# Copy this file to `.env` and fill in your real credentials.
# `.env` is git-ignored — never commit your actual keys.

# ---- IBM watsonx.ai (Granite) ----
WATSONX_API_KEY=your-watsonx-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ---- Hugging Face (optional, for baseline models) ----
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ---- Optional: default model identifiers ----
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
BASELINE_MODEL_ID=mistralai/mistral-7b-instruct-v0-2
