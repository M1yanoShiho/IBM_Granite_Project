# Copy this file to `.env` and fill in your real credentials.
# `.env` is git-ignored — never commit your actual keys.

# ---- IBM watsonx.ai (Granite) ----
WATSONX_API_KEY=your-watsonx-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com   # Dallas region; change if your instance is in eu-de / eu-gb / jp-tok

# ---- Hugging Face (optional: open-source baseline embeddings / self-hosting on HPC) ----
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ---- Model identifiers (confirm exact ids with IBM — see docs/meeting-1-questions.md Q4) ----
# Granite EMBEDDING model = the dense RETRIEVER (the delivered system).
GRANITE_EMBEDDING_MODEL_ID=ibm-granite/granite-embedding-278m-multilingual
# Granite GENERATIVE model = the RAG answer generator.
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
# Open-source dense-retriever baseline (sentence-transformers) for the system-vs-baseline comparison.
BASELINE_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
