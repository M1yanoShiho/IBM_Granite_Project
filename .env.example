# Copy this file to `.env` and adjust as needed.
# `.env` is git-ignored — never commit your actual keys.

# ---- IBM Granite (open-source, self-hosted from Hugging Face) ----
# IBM confirmed there is NO watsonx.ai API access for this project; we run the
# open-source Granite models (Apache 2.0) locally / on the HPC instead.
# A token is OPTIONAL for these public models — only needed for gated/private
# repos or to lift anonymous download rate limits. Leave blank otherwise.
HUGGINGFACE_API_KEY=

# ---- Model identifiers (Hugging Face repo ids) ----
# Granite EMBEDDING model = the dense RETRIEVER (the delivered system).
# Default: the latest (r2) English model — our benchmarks (SciFact/MS MARCO/NQ) are English.
# For fast pipeline development on CPU, switch to the tiny 47M model:
#   ibm-granite/granite-embedding-small-english-r2
GRANITE_EMBEDDING_MODEL_ID=ibm-granite/granite-embedding-english-r2
# Granite GENERATIVE model = the RAG answer generator. Start with 3B for dev;
# scale to 8B on the HPC (granite-4.1-8b-base supports a ~512K-token context).
GRANITE_MODEL_ID=ibm-granite/granite-4.1-3b
# Open-source dense-retriever baseline (sentence-transformers) for system-vs-baseline.
BASELINE_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2

# ---- Local inference / runtime ----
# Where downloaded weights are cached. On the HPC, point this at shared scratch
# storage so large weights are not re-downloaded per job. Blank = HF default cache.
MODEL_CACHE_DIR=
# Device for generation: "auto" (let accelerate place it), "cuda", or "cpu".
LLM_DEVICE=auto
